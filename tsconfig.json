{
	"compilerOptions": {
		"target": "ES2022",
		"lib": ["ES2022"],
		"module": "commonjs",
		"moduleResolution": "node",
		"outDir": "dist",
		"rootDir": ".",
		"strict": true,
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"sourceMap": true,
		"declaration": false,
		"skipLibCheck": true
	},
	"include": [
		"credentials/**/*.ts",
		"nodes/**/*.ts"
	],
	"exclude": [
		"node_modules",
		"dist"
	]
}
